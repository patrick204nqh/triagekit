{
  "name": "triagekit",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "triagekit": "./dist-cli/cli/index.js"
  },
  "scripts": {
    "build:cli": "tsc -p tsconfig.json",
    "build:pages": "npm run build:cli && node dist-cli/cli/index.js build --generic && mkdir -p docs && cp dist/triage.html docs/index.html && cp assets/og.png docs/og.png",
